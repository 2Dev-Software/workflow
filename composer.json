{
    "name": "2dev-software/workflow",
    "description": "Internal workflow management platform for school operations.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "mpdf/mpdf": "^8.2"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "pestphp/pest": "4.4.3",
        "phpunit/phpunit": "12.5.14",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test:baseline": "php scripts/regression-test.php",
        "test:phpunit": "phpunit --testsuite PHPUnit",
        "test:pest": "pest --testsuite Pest",
        "lint:php": "bash scripts/run-php-lint.sh --local",
        "analyze:phpstan": "phpstan analyse --configuration=phpstan.neon.dist --no-progress"
    }
}
