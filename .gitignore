# =========================================
# 1. SECURITY & ENVIRONMENT (สำคัญที่สุด 🔒)
# =========================================
.env
.env.docker
.env.local
.env.*.local

# =========================================
# 2. DEPENDENCIES
# (เราไม่อัปโหลด Library ขึ้น Git แต่จะใช้ composer install ที่ Server แทน)
# =========================================
/vendor/

# =========================================
# 3. USER UPLOADS
# (เก็บโฟลเดอร์ไว้ แต่ไม่เอาไฟล์ข้างใน)
# =========================================
/public/uploads/*
!/public/uploads/.gitkeep
/assets/uploads/*
!/assets/uploads/.gitkeep
!/assets/uploads/vehicle-bookings/
assets/uploads/vehicle-bookings/*
!/assets/uploads/vehicle-bookings/.gitkeep
/assets/img/profile/**
/storage/uploads/**
!/storage/uploads/
!/storage/uploads/.gitkeep
!/storage/uploads/.htaccess

# =========================================
# 4. SYSTEM & IDE FILES (ไฟล์ขยะ)
# =========================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# =========================================
# 5. LOGS & DEBUG
# =========================================
*.log
error_log
debug.log
.php-cs-fixer.cache
.phpunit.cache/

# =========================================
# 6. LOCAL EXPORTS & TEMP ARTIFACTS
# =========================================
LINUX*.sql
LINUX*.csv
tmp/pdfs/*
!tmp/pdfs/.gitkeep
tmp/phpstan/
tmp/mock-circular-seed/
docker/package/*
!docker/package/.gitkeep
docker/runtime-assets/*.tar.gz
docker/runtime-assets/*.sha256
